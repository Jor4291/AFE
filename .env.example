# Copy to .env.local for `vercel dev`, or set in Vercel → Project → Settings → Environment Variables
BASIC_AUTH_USER=demo
BASIC_AUTH_PASSWORD=change-me-before-deploy

# SiteGround MySQL (remote) — use your site IP from Site Tools, not "localhost"
# SiteGround: Site Tools → Site → MySQL → Remote (whitelist % or Vercel IPs)
MYSQL_HOST=your-siteground-server-ip
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_mysql_database
