# Copy to .env.local for `vercel dev`, or set in Vercel → Project → Settings → Environment Variables
#
# Connection identity is user@host — set MYSQL_USER + MYSQL_HOST separately,
# or combine as MYSQL_USER=u5s3nwinygnfy@35.209.193.155

MYSQL_HOST=35.209.193.155
MYSQL_PORT=3306
MYSQL_USER=u5s3nwinygnfy
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=dbnivmbmdqngwq

