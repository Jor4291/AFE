{
  "installCommand": "npm install",
  "buildCommand": "",
  "outputDirectory": "afe-rebuild/prototype",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/demo.html" },
    { "source": "/design", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
